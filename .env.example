# Hugging Face Token for pyannote.audio speaker diarization
# 1. Create account at https://huggingface.co
# 2. Accept terms at https://huggingface.co/pyannote/speaker-diarization-3.1
# 3. Create token at https://huggingface.co/settings/tokens
# 4. Copy this file to .env and add your token below

HF_TOKEN=Token_goes_here


# First time setup (only once):

# cd "C:\Personal Projects\speech-transcription-poc-whisperx-final"
# python -m venv venv
# .\venv\Scripts\Activate
# pip install torch torchaudio --index-url https://download.pytorch.org/whl/cpu
# pip install whisperx
# pip install -r requirements.txt


# Every session:

# cd "C:\Personal Projects\speech-transcription-poc-whisperx-final"
# .\venv\Scripts\Activate
# $env:HF_TOKEN = "Token_goes_here"
# python main.py --file "C:\path\to\audio.wav"


# Or for real-time transcription:

# python main.py